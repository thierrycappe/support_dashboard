DATABASE_URL=
AUTH_SECRET=
AUTH_TRUST_HOST=true
SUPPORT_DASHBOARD_ADMIN_EMAILS=
SUPPORT_DASHBOARD_ADMIN_PASSWORD_HASH=
# Development-only fallback. Production requires SUPPORT_DASHBOARD_ADMIN_PASSWORD_HASH.
SUPPORT_DASHBOARD_ADMIN_PASSWORD=
# Preferred production format: one independently rotatable token per app slug.
SUPPORT_TOWER_INGEST_TOKENS_JSON={"csm":"replace-me","casal-track":"replace-me","pitchme":"replace-me"}
# Optional public source app URL overrides used to rewrite localhost deep links.
SUPPORT_TOWER_SOURCE_APP_URLS_JSON={"pitchme":"https://pitchme-pearl.vercel.app"}
# Optional development fallback used only when SUPPORT_TOWER_INGEST_TOKENS_JSON is empty.
SUPPORT_TOWER_INGEST_TOKEN=
# Public URL used in push notification deep links. Vercel can also provide VERCEL_URL.
SUPPORT_TOWER_PUBLIC_URL=
# Optional Pushover alerting for newly created tower tickets.
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
# Optional Resend email digest for the daily open-ticket report.
RESEND_API_KEY=
RESEND_FROM=
SUPPORT_TOWER_DIGEST_EMAIL_TO=
# Required in production for Vercel Cron authorization.
CRON_SECRET=
# Optional outbound pull configuration. Maps a source app slug to a pull endpoint and bearer token.
# The endpoint must accept GET <url>?since=<iso8601> and GET <url>?externalId=<id>, returning
# { "tickets": FeedbackIngestPayload[] }. Used by /api/cron/sync-source-apps and the per-ticket
# "Refresh from source" button.
SUPPORT_TOWER_SOURCE_APP_PULL_JSON={"casal-track":{"url":"https://casal-track.example.com/api/support-tower/export","token":"replace-me"}}
